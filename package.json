{
  "name": "codeoba",
  "private": true,
  "version": "0.8.9",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "node scripts/download-privacy.cjs && tsc && vite build",
    "preview": "vite preview",
    "tauri": "node scripts/tauri.cjs",
    "build:local": "node scripts/tauri.cjs build --config \"{\\\"bundle\\\": {\\\"createUpdaterArtifacts\\\": false, \\\"targets\\\": [\\\"app\\\"]}}\"",
    "build:exe": "node scripts/tauri.cjs build --no-bundle",
    "bump": "node scripts/bump-version.cjs",
    "generate-keys": "node scripts/generate-keys.cjs",
    "translate": "node scripts/translate.cjs",
    "test:menu": "node scripts/test-menu-alignment.js",
    "format:fe": "prettier --write \"src/**/*.{ts,tsx,css,html}\"",
    "format:fe:check": "prettier --check \"src/**/*.{ts,tsx,css,html}\"",
    "lint:fe": "eslint src",
    "format:be": "cargo fmt --manifest-path src-tauri/Cargo.toml",
    "format:be:check": "cargo fmt --manifest-path src-tauri/Cargo.toml -- --check",
    "clippy": "cargo clippy --manifest-path src-tauri/Cargo.toml --all-targets --no-default-features -- -D warnings",
    "format": "npm run format:fe && npm run format:be",
    "lint": "npm run format:fe:check && npm run lint:fe && npm run format:be:check && npm run clippy",
    "qa": "npm run lint && cargo test --manifest-path src-tauri/Cargo.toml && npm run build",
    "prepare": "git config core.hooksPath .githooks || true",
    "clean:be": "cargo clean --manifest-path src-tauri/Cargo.toml",
    "clean:fe": "rm -rf node_modules dist .vite",
    "clean": "npm run clean:be && npm run clean:fe"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-process": "^2",
    "@tauri-apps/plugin-updater": "^2",
    "dompurify": "^3.4.12",
    "lucide-solid": "^1.24.0",
    "marked": "^18.0.6",
    "mermaid": "^11.16.0",
    "prismjs": "^1.30.0",
    "solid-js": "^1.9.14",
    "tailwindcss": "^4.3.2"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@babel/eslint-parser": "^7.29.7",
    "@babel/preset-typescript": "^7.29.7",
    "@tauri-apps/cli": "^2",
    "@types/prismjs": "^1.26.6",
    "eslint": "^9.39.5",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-solid": "^0.14.5",
    "prettier": "^3.9.5",
    "typescript": "~7.0.2",
    "vite": "^8.1.4",
    "vite-plugin-solid": "^2.11.12"
  },
  "allowScripts": {
    "esbuild@0.28.1": true,
    "fsevents@2.3.3": true
  }
}
