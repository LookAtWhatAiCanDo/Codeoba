{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Codeoba",
  "version": "0.6.3",
  "identifier": "com.whataicando.codeoba",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "node scripts/prepare-installers.cjs && npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Codeoba",
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "theme": "Dark",
        "backgroundColor": "#0f1015",
        "transparent": true,
        "acceptFirstMouse": true,
        "width": 800,
        "height": 600,
        "center": true,
        "devtools": true,
        "visible": false,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' ipc: http://ipc.localhost https://codeoba.com https://*.codeoba.com; img-src 'self' asset: http://asset.localhost blob: data:; style-src 'self' 'unsafe-inline'; font-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "resources": [
      "resources/onnx/model.onnx",
      "resources/onnx/vocab.txt"
    ],
    "targets": "all",
    "publisher": "WhatAiCanDo",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "template": "nsis/installer.nsi"
      },
      "wix": {
        "template": "main.wxs"
      }
    }
  },
  "plugins": {
    "updater": {
      "active": false,
      "pubkey": "",
      "endpoints": [],
      "dialog": false,
      "windows": {
        "installMode": "passive",
        "installerArgs": [
          "/UPDATE"
        ]
      }
    }
  }
}
